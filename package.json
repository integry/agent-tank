{
  "name": "agent-tank",
  "version": "0.9.5",
  "description": "Monitor and query usage limits for LLM CLI tools (Claude, Gemini, Codex) via HTTP API",
  "main": "src/index.js",
  "bin": {
    "agent-tank": "bin/agent-tank.js"
  },
  "scripts": {
    "start": "node bin/agent-tank.js",
    "dev": "node bin/agent-tank.js",
    "lint": "eslint src/ bin/",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:e2e": "jest --testPathPattern=test/e2e",
    "install": "node scripts/install.js || true",
    "rebuild": "PYTHON=$(which python3.11 || which python3.10 || which python3.9 || which python3.8 || which python3) npm rebuild node-pty"
  },
  "keywords": [
    "llm",
    "claude",
    "gemini",
    "codex",
    "openai",
    "anthropic",
    "google",
    "usage",
    "limits",
    "rate-limit",
    "monitor",
    "cli",
    "api"
  ],
  "author": "Rinalds Uzkalns (https://propr.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/integry/agent-tank.git"
  },
  "bugs": {
    "url": "https://github.com/integry/agent-tank/issues"
  },
  "homepage": "https://agenttank.io",
  "dependencies": {
    "node-pty": "^1.0.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "media/",
    "LICENSE",
    "README.md"
  ]
}
